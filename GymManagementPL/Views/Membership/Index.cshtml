@using GymMangementBLL.ViewModels.MembershipViewModels
@model IEnumerable<MembershipViewModel>

@{
    ViewData["Title"] = "Active Memberships";
}

<div class="container-fluid">
    <header class="bg-primary text-white rounded-3 p-4 shadow-sm mt-5 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1 fw-semibold">Active Memberships</h2>
                <p class="mb-0 text-light opacity-75">Members That Have Active Plans</p>
            </div>
            <div class="col text-end">
                <a asp-action="Create" class="btn btn-light">
                    <i class="bi bi-plus-lg me-1"></i> New Membership
                </a>
            </div>
        </div>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div id="AlertSuccess" class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div id="AlertError" class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Member</th>
                            <th>Plan</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MemberName</td>
                                <td>@item.PlanName</td>
                                <td>@item.StartDate</td>
                                <td>@item.EndDate</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <button type="button"
                                                class="btn btn-sm btn-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#cancelModal"
                                                data-member-id="@item.MemberId"
                                                data-plan-id="@item.PlanId"
                                                data-member-name="@item.MemberName"
                                                data-plan-name="@item.PlanName">
                                            <i class="bi bi-x-lg me-1"></i> Cancel
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-person-workspace display-1 text-muted"></i>
                    <h4 class="mt-3 text-muted">No Active Memberships Available</h4>
                </div>
            }
        </div>
    </div>
</div>

<!-- Cancel Confirmation Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-body text-center p-5">
                <div class="mb-3">
                    <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 3.5rem;"></i>
                </div>
                <h4 class="fw-bold mb-2">Cancel Membership?</h4>
                <p class="text-muted mb-1">You are about to cancel the membership for:</p>
                <p class="fw-semibold fs-5 mb-1" id="modalMemberName">—</p>
                <p class="text-muted mb-0">Plan: <span class="text-dark fw-medium" id="modalPlanName">—</span></p>

                <div class="alert alert-warning text-start mt-4 mb-0" role="alert">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>This action cannot be undone.</strong> The membership will be permanently removed.
                </div>
            </div>

            <div class="modal-footer border-0 px-5 pb-4 pt-0 justify-content-between gap-3">
                <button type="button" class="btn btn-outline-secondary flex-fill" data-bs-dismiss="modal">
                    <i class="bi bi-arrow-left me-1"></i> No, Keep It
                </button>
                <form id="cancelForm" asp-action="Cancel" method="post" class="flex-fill m-0">
                    <input type="hidden" id="modalMemberId" name="memberId" value="" />
                    <input type="hidden" id="modalPlanId" name="planId" value="" />
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="bi bi-x-lg me-1"></i> Yes, Cancel It
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            ["AlertSuccess", "AlertError"].forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    setTimeout(() => {
                        el.style.transition = "opacity 0.5s ease";
                        el.style.opacity = "0";
                        setTimeout(() => el.remove(), 500);
                    }, 3000);
                }
            });
        });

        document.getElementById("cancelModal").addEventListener("show.bs.modal", function (event) {
            const btn = event.relatedTarget;
            document.getElementById("modalMemberName").textContent = btn.dataset.memberName;
            document.getElementById("modalPlanName").textContent = btn.dataset.planName;
            document.getElementById("modalMemberId").value = btn.dataset.memberId;
            document.getElementById("modalPlanId").value = btn.dataset.planId;
        });
    </script>
}

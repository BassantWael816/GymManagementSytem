@using GymMangementBLL.ViewModels.SessionViewModels

@{
    ViewData["Title"] = "Sessions Schedule";
    var upcomingSessions = ViewBag.UpcomingSessions as IEnumerable<SessionViewModel> ?? Enumerable.Empty<SessionViewModel>();
    var ongoingSessions = ViewBag.OngoingSessions as IEnumerable<SessionViewModel> ?? Enumerable.Empty<SessionViewModel>();
}

<div class="container">
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">Member Sessions</h2>
            <p class="text-muted">Sessions Valid For Manage Booking</p>
        </div>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div id="AlertSuccess" class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div id="AlertError" class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Upcoming Sessions -->
    @if (upcomingSessions.Any())
    {
        <div class="row g-4">
            @foreach (var session in upcomingSessions)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 session-card">
                        <div class="card-header text-white py-3 bg-primary">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">
                                    <i class="bi bi-calendar-event me-2"></i>@session.CategoryName
                                </h5>
                                <span class="badge bg-light text-dark">Upcoming</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-3">@session.Description</p>
                            <div class="session-info mb-3">
                                <div class="info-item mb-2">
                                    <i class="bi bi-person-circle text-primary-color me-2"></i>
                                    <strong>Trainer:</strong> @session.TrainerName
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-calendar3 text-primary-color me-2"></i>
                                    <strong>Date:</strong> @session.StartDate.ToString("MMM dd, yyyy")
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-clock text-primary-color me-2"></i>
                                    <strong>Time:</strong> @session.StartDate.ToString("hh:mm tt") - @session.EndDate.ToString("hh:mm tt")
                                </div>
                                <div class="info-item">
                                    <i class="bi bi-people text-primary-color me-2"></i>
                                    <strong>Capacity:</strong> @(session.Capacity - session.AvailableSlots)/@session.Capacity slots
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <div class="d-grid gap-2">
                                <a asp-action="GetMembersForUpcomingSession" asp-route-sessionId="@session.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye me-1"></i> View Members
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-4">
            <i class="bi bi-calendar-x display-4 text-muted"></i>
            <h5 class="mt-3 text-muted">No Upcoming Sessions</h5>
        </div>
    }

    <!-- Ongoing Sessions -->
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">Ongoing Sessions</h2>
            <p class="text-muted">Sessions Valid For Manage Attendance</p>
        </div>
    </header>

    @if (ongoingSessions.Any())
    {
        <div class="row g-4">
            @foreach (var session in ongoingSessions)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 session-card">
                        <div class="card-header text-white py-3 bg-success">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">
                                    <i class="bi bi-calendar-event me-2"></i>@session.CategoryName
                                </h5>
                                <span class="badge bg-light text-dark">Ongoing</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-3">@session.Description</p>
                            <div class="session-info mb-3">
                                <div class="info-item mb-2">
                                    <i class="bi bi-person-circle text-primary-color me-2"></i>
                                    <strong>Trainer:</strong> @session.TrainerName
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-calendar3 text-primary-color me-2"></i>
                                    <strong>Date:</strong> @session.StartDate.ToString("MMM dd, yyyy")
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-clock text-primary-color me-2"></i>
                                    <strong>Time:</strong> @session.StartDate.ToString("hh:mm tt") - @session.EndDate.ToString("hh:mm tt")
                                </div>
                                <div class="info-item">
                                    <i class="bi bi-people text-primary-color me-2"></i>
                                    <strong>Capacity:</strong> @(session.Capacity - session.AvailableSlots)/@session.Capacity slots
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <div class="d-grid gap-2">
                                <a asp-action="GetMembersForOngoingSessions" asp-route-sessionId="@session.Id"
                                   class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-eye me-1"></i> View Members
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-4">
            <i class="bi bi-calendar-x display-4 text-muted"></i>
            <h5 class="mt-3 text-muted">No Ongoing Sessions</h5>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            ["AlertSuccess", "AlertError"].forEach(id => {
                const el = document.getElementById(id);
                if (el) setTimeout(() => { el.style.transition = "opacity 0.5s"; el.style.opacity = "0"; setTimeout(() => el.remove(), 500); }, 3000);
            });
        });
    </script>
}

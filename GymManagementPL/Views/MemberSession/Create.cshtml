@model GymMangementBLL.ViewModels.MemberSessionViewModels.CreateBookingViewModel

@{
    ViewData["Title"] = "Create New Booking";
}

<h1>Create New Booking</h1>
<hr />

<div class="row">
    <div class="d-flex justify-content-center align-items-center h-100">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Booking Information</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="SessionId" value="@ViewBag.SessionId" />

                        <div class="mb-3">
                            <label asp-for="MemberId" class="form-label">Member</label>
                            <select asp-for="MemberId" asp-items="ViewBag.Members" class="form-select">
                                <option value="">-- Select Member --</option>
                            </select>
                            <span asp-validation-for="MemberId" class="text-danger"></span>
                            <small class="text-muted">Only members with active memberships are shown</small>
                        </div>

                        <div class="mb-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i> Create Booking
                            </button>
                            <a asp-action="GetMembersForUpcomingSession" asp-route-sessionId="@ViewBag.SessionId"
                               class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
